# ============================================
# Industry Dashboard Configuration
# ============================================
# Step 1: cp default.env.example .env
# Step 2: (Optional) Change DB_PASSWORD and JWT_SECRET for production
# Step 3: docker compose -f docker-compose.production.yml up -d db
# Step 4: source .env && ./dashboard-server-<platform>
# ============================================

# Database
DB_USER=dashboard
DB_PASSWORD=dashboard
DB_HOST=localhost
DB_PORT=5432
DB_NAME=industry_dashboard

# Server
PORT=8080
JWT_SECRET=dashboard-dev-secret

# Azure AD SSO (leave empty to use dev mode login)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=

# ============================================
# PRODUCTION: Change DB_PASSWORD and JWT_SECRET
# to secure random values before going live!
# ============================================
