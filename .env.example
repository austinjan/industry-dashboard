# ============================================
# Industry Dashboard Configuration
# Copy this file: cp default.env.example .env
# Then change the passwords below
# ============================================

# Database password — change this!
DB_PASSWORD=change-me

# JWT secret — change this to a random string!
JWT_SECRET=change-me-to-a-random-string

# Server port
PORT=8080

# Database (usually no need to change)
DB_USER=dashboard
DB_NAME=industry_dashboard
DB_PORT=5432

# Azure AD SSO (leave empty to use dev mode login)
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_TENANT_ID=
